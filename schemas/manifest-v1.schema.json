{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "The Exporter Migration Manifest",
  "type": "object",
  "required": ["schema_version", "migration_id", "source", "components"],
  "properties": {
    "schema_version": { "type": "string" },
    "migration_id": { "type": "string", "format": "uuid" },
    "export_started_at": { "type": "string", "format": "date-time" },
    "export_completed_at": { "type": ["string", "null"], "format": "date-time" },
    "source": {
      "type": "object",
      "properties": {
        "wp_version": { "type": "string" },
        "php_version": { "type": "string" },
        "mysql_version": { "type": "string" },
        "site_url": { "type": "string" },
        "home_url": { "type": "string" },
        "table_prefix": { "type": "string" }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "chunk_count": { "type": "integer" },
          "total_bytes": { "type": "integer" },
          "inventory_file": { "type": "string" }
        }
      }
    },
    "checksums": {
      "type": "object",
      "properties": {
        "manifest_sha256": { "type": ["string", "null"] },
        "chunks": { "type": "object" }
      }
    }
  }
}
